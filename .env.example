# Required
JWT_SECRET=generate-a-long-random-secret
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Recommended on Railway
NODE_ENV=production
APP_URL=https://your-app.example.com
WEBHOOK_VERIFY_TOKEN=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Facebook / Instagram OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://your-app.up.railway.app/auth/facebook/callback

# Personal Telegram account (MTProto — https://my.telegram.org/apps)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Set to false to disable GramJS NewMessage listeners on startup
TELEGRAM_LISTENER_ENABLED=true
# Instagram webhook events worker (processes rows from webhook_events table)
WEBHOOK_EVENTS_WORKER_ENABLED=true
# Max events processed in parallel per poll
WEBHOOK_EVENTS_WORKER_CONCURRENCY=4
# Idle wait when no pending events (ms)
WEBHOOK_EVENTS_WORKER_POLL_INTERVAL_MS=1000
# Failed events are retried until attempts reach this limit
WEBHOOK_EVENTS_WORKER_MAX_ATTEMPTS=5

# Optional
SWAGGER_ENABLED=false
DB_SSL=true
OPENAI_API_KEY=
CF_ACCOUNT_ID=
CF_API_KEY=

# SendGrid (dynamic template emails)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
# Registration confirmation template variables: first_name, company_name, confirm_url
SENDGRID_REGISTRATION_TEMPLATE_ID=
# Invitation template variables: name, invitationLink
